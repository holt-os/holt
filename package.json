  "author": "Debashis Nayak",
  "homepage": "https://productsdecoded.com/holt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holt-os/holt.git"
  },
  "bugs": {
    "url": "https://github.com/holt-os/holt/issues"
  },
  "keywords": [
    "ai",
